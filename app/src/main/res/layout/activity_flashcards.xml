<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="20dp"
        android:paddingBottom="14dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/icon_btn_background">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FFFFFF"
                android:contentDescription="Back"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Study Set"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>

        <TextView
            android:id="@+id/tvCardCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 of 10"
            android:textColor="#5A7A9A"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:progressTint="#7F77DD"
        android:progressBackgroundTint="#111f33"
        android:layout_marginBottom="24dp"/>

    <!-- Flashcard -->
    <androidx.cardview.widget.CardView
        android:id="@+id/flashcard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#111f33"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:id="@+id/tvQuestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Question appears here"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="24dp"/>

            <View
                android:layout_width="56dp"
                android:layout_height="2dp"
                android:background="#7F77DD"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/tvAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Answer appears here"
                android:textColor="#7F77DD"
                android:textSize="17sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"
                android:visibility="gone"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/tvTapHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap card to flip"
                android:textColor="#3D5570"
                android:textSize="13sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Prev / Next -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btnPrevious"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="← Prev"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:backgroundTint="#111f33"
            android:layout_marginEnd="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="Next →"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:backgroundTint="#7F77DD"
            android:layout_marginStart="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>
    </LinearLayout>
</LinearLayout>