<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Study Generator"
            android:textColor="#7F77DD"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paste your notes below to generate flashcards instantly."
            android:textColor="#8899AA"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"/>

        <!-- AI Input -->
        <EditText
            android:id="@+id/etAiInput"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Paste textbook text, notes, or a topic here..."
            android:textColorHint="#556070"
            android:textColor="#FFFFFF"
            android:padding="16dp"
            android:gravity="top"
            android:background="@drawable/input_background"
            android:layout_marginBottom="12dp"/>

        <!-- How many cards to generate -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How many flashcards?"
            android:textColor="#AABBCC"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgCardCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rb5"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="5"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:buttonTint="#7F77DD"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb10"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="10"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:buttonTint="#7F77DD"/>

            <RadioButton
                android:id="@+id/rb15"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="15"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:buttonTint="#7F77DD"/>

            <RadioButton
                android:id="@+id/rb20"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="20"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:buttonTint="#7F77DD"/>

        </RadioGroup>

        <Button
            android:id="@+id/btnGenerateAi"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="✨ Generate Flashcards"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#7F77DD"
            android:layout_marginBottom="12dp"/>

        <ProgressBar
            android:id="@+id/aiProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="20dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#162032"
            android:layout_marginBottom="24dp"/>

        <!-- Manual Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Study Set Details"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Title"
            android:textColorHint="#556070"
            android:textColor="#FFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_background"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="Description (optional)"
            android:textColorHint="#556070"
            android:textColor="#FFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="top"
            android:background="@drawable/input_background"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:id="@+id/cardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <Button
            android:id="@+id/btnAddCard"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="+ Add Card Manually"
            android:textColor="#7F77DD"
            android:backgroundTint="#162032"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Study Set"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#7F77DD"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>