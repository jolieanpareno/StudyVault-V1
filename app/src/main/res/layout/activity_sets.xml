<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/header_gradient"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/icon_btn_background"
            android:tint="#FFFFFF"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Study Set"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete"
            android:background="@drawable/icon_btn_background"
            android:tint="#E74C3C"
            android:contentDescription="Delete"/>
    </LinearLayout>

    <!-- Title + Description -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tvSetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Title"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvSetDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="#5A7A9A"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Card count label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HOW MANY CARDS?"
        android:textColor="#3D5570"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:textStyle="bold"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"/>

    <!-- Stepper row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/search_background"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btnMinus"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="−"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#162032"
            android:padding="0dp"/>

        <TextView
            android:id="@+id/tvCardCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="10"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnPlus"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#162032"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnAll"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:text="ALL"
            android:textSize="12sp"
            android:textColor="#7F77DD"
            android:textStyle="bold"
            android:backgroundTint="#1A2840"
            android:layout_marginStart="10dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>
    </LinearLayout>

    <!-- Flashcards button -->
    <Button
        android:id="@+id/btnFlashcards"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="📖  Study Flashcards"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#7F77DD"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="10dp"/>

    <!-- Quiz button -->
    <Button
        android:id="@+id/btnQuiz"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="🧠  Take Quiz"
        android:textColor="#7F77DD"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#111f33"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"/>

</LinearLayout>